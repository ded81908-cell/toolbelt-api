{
  "name": "toolbelt-api",
  "version": "1.0.0",
  "description": "Toolbelt API — a pay-as-you-go developer utility API: QR codes, OG images, data conversion, hashing/encoding, and generators. Zero AI cost, marketplace-ready.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "api",
    "qrcode",
    "og-image",
    "csv",
    "json",
    "yaml",
    "hash",
    "developer-tools",
    "rapidapi"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.11.1",
    "fastify": "^4.28.1",
    "js-yaml": "^4.1.0",
    "libphonenumber-js": "^1.13.4",
    "marked": "^18.0.4",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.4",
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/ua-parser-js": "^0.7.39",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}

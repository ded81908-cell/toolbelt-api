{
  "name": "toolbelt-api",
  "version": "1.0.0",
  "description": "Toolbelt API — a pay-as-you-go developer utility API: QR codes, OG images, data conversion, hashing/encoding, and generators. Zero AI cost, marketplace-ready.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "api",
    "qrcode",
    "og-image",
    "csv",
    "json",
    "yaml",
    "hash",
    "developer-tools",
    "rapidapi"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "bwip-js": "^4.11.1",
    "fastify": "^4.28.1",
    "js-yaml": "^4.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}

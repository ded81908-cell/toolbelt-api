# ----- Toolbelt API configuration -----

# Port the server listens on
PORT=3000
HOST=0.0.0.0

# Comma-separated list of API keys that are accepted for direct (self-hosted) access.
# Format: key:tier  (tier is one of: free, pro, ultra). Tier controls rate limits.
# Example: API_KEYS=demo-key-123:free,paying-customer-abc:pro
API_KEYS=demo-key:free

# Set to "true" to allow unauthenticated access (handy for local dev only).
ALLOW_ANONYMOUS=false

# RapidAPI integration: when you list the API on RapidAPI, the gateway forwards a
# shared secret on every request. Set this to the value shown in your RapidAPI
# "Security" settings so only RapidAPI traffic is trusted (billing handled by them).
RAPIDAPI_PROXY_SECRET=

# Per-minute request limits per tier (used by the rate limiter).
RATE_LIMIT_FREE=30
RATE_LIMIT_PRO=300
RATE_LIMIT_ULTRA=3000
